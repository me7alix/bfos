#!/usr/bin/env python3
"""
Translate a string to "sendkey" commands for QEMU (Python port).
Original Ruby by Martin Vidner (MIT License).
"""

import argparse
import subprocess
import sys
import time

# Same mappings as the original
UPCASE = [(c, f"shift-{c.lower()}") for c in "ABCDEFGHIJKLMNOPQRSTUVWXYZ"]
KEYS = {
    " ": "spc", "!": "shift-1", '"': "shift-apostrophe", "#": "shift-3",
    "$": "shift-4", "%": "shift-5", "&": "shift-7", "'": "apostrophe",
    "(": "shift-9", ")": "shift-0", "*": "shift-8", "+": "shift-equal",
    ",": "comma", "-": "minus", ".": "dot", "/": "slash",
    ":": "shift-semicolon", ";": "semicolon", "<": "shift-comma",
    "=": "equal", ">": "shift-dot", "?": "shift-slash", "@": "shift-2",
    "[": "bracket_left", "\\": "backslash", "]": "bracket_right",
    "^": "shift-6", "_": "shift-minus", "`": "grave_accent",
    "{": "shift-bracket_left", "|": "shift-backslash",
    "}": "shift-bracket_right", "~": "shift-grave_accent",
}
KEYS.update(dict(UPCASE))

# Only these are recognised as special <tags>
VALID_TAG_CHARS = set("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_-")
SPECIAL = {"delay", "lt", "gt", "ret", "backspace", "tab", "esc",
           "f1", "f2", "f3", "f4", "f5", "f6", "f7", "f8", "f9", "f10", "f11", "f12",
           "home", "pgup", "pgdn", "end", "left", "up", "down", "right", "insert", "delete"}


class Sendkeys:
    def __init__(self):
        p = argparse.ArgumentParser()
        p.add_argument("-c", "--command", help="pipe each sendkey to this command")
        p.add_argument("string", nargs="?", default="")
        self.args = p.parse_args()
        self.cmd = self.args.command

    def send(self, k: str):
        if self.cmd:
            subprocess.run(f"echo 'sendkey {k}' | {self.cmd}", shell=True)
        else:
            print(f"sendkey {k}")
            sys.stdout.flush()
        time.sleep(0.025)

    def run(self):
        s = self.args.string
        i = 0
        while i < len(s):
            if s[i] == "<":
                j = s.find(">", i + 1)
                if j != -1:
                    tag = s[i + 1 : j]
                    # Is this a real special tag?
                    if tag and all(c in VALID_TAG_CHARS for c in tag):
                        i = j + 1
                        if tag == "delay":
                            time.sleep(1)
                            continue
                        k = {"lt": "shift-comma", "gt": "shift-dot"}.get(tag, tag)
                    else:
                        # BF-style literal "<" or malformed tag → treat as normal "<"
                        k = KEYS.get("<", "<")
                        i += 1
                else:
                    # unclosed "<" at end
                    k = KEYS.get("<", "<")
                    i += 1
            else:
                ch = s[i]
                k = KEYS.get(ch, ch)
                i += 1
            self.send(k)


if __name__ == "__main__":
    Sendkeys().run()
